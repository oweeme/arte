{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arte",
  "version": "0.1.0",
  "identifier": "com.oweeme.arte",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Arte",
        "width": 1000,
        "height": 700,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Hector Martinez",
    "copyright": "© 2025 Hector Martinez — oweeme.com",
    "category": "Graphics and Design",
    "shortDescription": "Dibujo vectorial 3D",
    "longDescription": "Arte es una aplicación de dibujo vectorial 3D con perspectiva real. Crea ilustraciones, exporta a SVG, JPG y OBJ.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/com.oweeme.arte.metainfo.xml": "../flatpak/com.oweeme.arte.metainfo.xml"
        }
      }
    }
  }
}
